# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# .gitignore — IronPath Monorepo
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Couvre : Gradle, Node, Expo, IntelliJ, VSCode, Docker, env

# ━━━━ Fichiers sensibles ━━━━
.env
.env.local
.env.production
*.pem
*.key

# ━━━━ Gradle (Backend Kotlin) ━━━━
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# ━━━━ Java / Kotlin ━━━━
*.class
*.jar
!**/gradle-wrapper.jar
*.war
*.ear
hs_err_pid*
replay_pid*

# ━━━━ Node.js (Frontend Angular + Mobile React Native) ━━━━
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# ━━━━ Angular ━━━━
dist/
.angular/
*.tsbuildinfo

# ━━━━ Expo / React Native ━━━━
.expo/
__generated__/
*.jks
*.p8
*.p12
*.mobileprovision
ios/
android/
web-build/

# ━━━━ IDE — IntelliJ IDEA ━━━━
.idea/
*.iml
*.iws
*.ipr
out/

# ━━━━ IDE — VSCode ━━━━
.vscode/
*.code-workspace

# ━━━━ OS ━━━━
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ━━━━ Docker ━━━━
docker-compose.override.yml

# ━━━━ Coverage & Reports ━━━━
coverage/
*.lcov
test-results/
htmlcov/
